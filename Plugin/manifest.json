{
  "manifest_version": 3,
  "name": "RedBox Capture",
  "description": "将网页、链接、选中文字、图片、小红书和 YouTube 内容直接保存到 RedBox 知识库或素材库。",
  "version": "1.9.5",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "contextMenus",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:31937/*",
    "http://localhost:31937/*",
    "http://127.0.0.1:23456/*",
    "http://localhost:23456/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pageObserver.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pageRouteBridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "RedBox Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
