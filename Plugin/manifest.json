{
  "manifest_version": 3,
  "name": "RedBox Capture",
  "description": "将小红书、YouTube、网页链接和选中文字直接保存到 RedBox 知识库。",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:23456/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.xiaohongshu.com/*",
        "*://mp.weixin.qq.com/*",
        "*://*.youtube.com/*",
        "*://youtu.be/*"
      ],
      "js": ["pageObserver.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "RedBox Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
