{
  "name": "red-convert-desktop",
  "version": "1.8.7",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jamailar/RedBox.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['dist','dist-electron','release'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}));\"",
    "dev": "pnpm run prepare:private-runtime && pnpm run prepare:plugin-runtime && pnpm run sync:prompt-library && vite",
    "prepare:private-runtime": "node scripts/prepare-private-runtime.cjs",
    "prepare:plugin-runtime": "node scripts/prepare-plugin-runtime.cjs",
    "prepare:ffmpeg": "node scripts/ensure-ffmpeg-static.cjs",
    "sync:prompt-library": "node scripts/sync-prompt-library.cjs",
    "build": "pnpm run prepare:private-runtime && pnpm run prepare:plugin-runtime && pnpm run prepare:ffmpeg && pnpm run clean && tsc && vite build && pnpm run sync:prompt-library && electron-builder",
    "build:mac": "pnpm run prepare:private-runtime && pnpm run prepare:plugin-runtime && pnpm run prepare:ffmpeg && pnpm run clean && tsc && vite build && pnpm run sync:prompt-library && electron-builder --mac --x64 --arm64",
    "build:win": "pnpm run prepare:private-runtime && pnpm run prepare:plugin-runtime && pnpm run prepare:ffmpeg && pnpm run clean && tsc && vite build && pnpm run sync:prompt-library && electron-builder --win --x64",
    "build:all": "pnpm run prepare:private-runtime && pnpm run prepare:plugin-runtime && pnpm run prepare:ffmpeg && pnpm run clean && tsc && vite build && pnpm run sync:prompt-library && electron-builder --mac --x64 --arm64 --win --x64",
    "build:mac:nosign": "pnpm run prepare:private-runtime && pnpm run prepare:plugin-runtime && pnpm run prepare:ffmpeg && pnpm run clean && tsc && vite build && pnpm run sync:prompt-library && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --x64 --arm64 -c.mac.identity=null",
    "build:nosign": "pnpm run prepare:private-runtime && pnpm run prepare:plugin-runtime && pnpm run prepare:ffmpeg && pnpm run clean && tsc && vite build && pnpm run sync:prompt-library && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview"
  },
  "build": {
    "productName": "RedBox",
    "artifactName": "RedBox-${version}-${arch}.${ext}",
    "appId": "com.redbox.app",
    "directories": {
      "output": "release"
    },
    "compression": "maximum",
    "files": [
      "dist-electron/**",
      "dist/**",
      "electron/system-skills/**",
      ".private-runtime/**",
      ".plugin-runtime/**",
      "package.json",
      "redbox.png",
      "!node_modules/better-sqlite3/deps/**",
      "!node_modules/better-sqlite3/src/**",
      "!node_modules/openai/src/**",
      "!node_modules/zod/src/**",
      "!node_modules/@ai-sdk/**",
      "!node_modules/ai/**",
      "!node_modules/js-tiktoken/**",
      "!node_modules/@uiw/**",
      "!node_modules/@codemirror/**",
      "!node_modules/@xyflow/**",
      "!node_modules/lucide-react/**",
      "!node_modules/react/**",
      "!node_modules/react-dom/**",
      "!node_modules/refractor/**",
      "!node_modules/@lezer/**",
      "!node_modules/langsmith/**",
      "!node_modules/@opentelemetry/**"
    ],
    "icon": "redbox.png",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "redbox.png",
      "identity": "Hunan Xizi Culture Co., Ltd. (N9KF8X5S99)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "CFBundleDisplayName": "RedBox",
        "CFBundleName": "RedBox",
        "NSCameraUsageDescription": "This app requires camera access to record videos."
      },
      "notarize": {
        "teamId": "N9KF8X5S99"
      }
    },
    "asarUnpack": [
      "**/*.node",
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "redbox.png"
    },
    "linux": {
      "icon": "redbox.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Jamailar",
      "repo": "RedBox",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.18",
    "@ai-sdk/openai": "^3.0.14",
    "@ai-sdk/openai-compatible": "^2.0.16",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.11",
    "@google/genai": "^1.45.0",
    "@lezer/highlight": "^1.2.3",
    "@mariozechner/pi-agent-core": "^0.58.0",
    "@mariozechner/pi-ai": "^0.58.0",
    "@mozilla/readability": "0.6.0",
    "@types/glob": "^8.1.0",
    "@uiw/react-codemirror": "^4.25.4",
    "@uiw/react-md-editor": "^4.0.11",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.45",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^11.8.0",
    "bindings": "^1.5.0",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.0",
    "decimal.js": "^10.6.0",
    "diff": "^5.1.0",
    "duck-duck-scrape": "^2.2.7",
    "esprima": "^4.0.1",
    "ffmpeg-static": "^5.3.0",
    "file-uri-to-path": "^1.0.0",
    "glob": "^13.0.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.0.1",
    "lucide-react": "^0.300.0",
    "nanoid": "^5.1.6",
    "openai": "^6.26.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.2.0",
    "tippy.js": "^6.3.7",
    "turndown": "7.2.2",
    "ulid": "^3.0.2",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-types": "^3.17.5",
    "ws": "^8.19.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/diff": "^5.0.8",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "28.3.3",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.0",
    "prebuild-install": "^7.1.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
