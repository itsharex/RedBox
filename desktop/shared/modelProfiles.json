[
    {
        "id": "openai-gpt-5-family",
        "vendor": "openai",
        "displayName": "OpenAI GPT-5 family",
        "matchers": [
            "\\bgpt-5\\b",
            "\\bgpt-5-mini\\b",
            "\\bgpt-5-nano\\b",
            "\\bgpt-5\\.1\\b",
            "\\bgpt-5\\.2\\b",
            "\\bgpt-5-codex\\b",
            "\\bgpt-5\\.1-codex\\b",
            "\\bgpt-5\\.2-codex\\b"
        ],
        "capabilities": ["chat"],
        "inputCapabilities": ["image", "file"],
        "notes": "Current GPT-5 family pages advertise text/image input and file-search/file workflows; audio/video input is not assumed for the base family."
    },
    {
        "id": "openai-gpt-4o-family",
        "vendor": "openai",
        "displayName": "OpenAI GPT-4o family",
        "matchers": [
            "\\bgpt-4o\\b",
            "\\bgpt-4o-mini\\b",
            "\\bchatgpt-4o\\b"
        ],
        "capabilities": ["chat"],
        "inputCapabilities": ["image", "file"],
        "notes": "Text + image understanding. PDF/file support is handled conservatively as file input."
    },
    {
        "id": "openai-gpt-4.1-family",
        "vendor": "openai",
        "displayName": "OpenAI GPT-4.1 family",
        "matchers": [
            "\\bgpt-4\\.1\\b",
            "\\bgpt-4\\.1-mini\\b",
            "\\bgpt-4\\.1-nano\\b"
        ],
        "capabilities": ["chat"],
        "inputCapabilities": ["image", "file"],
        "notes": "Text + image understanding. PDF/file support is handled conservatively as file input."
    },
    {
        "id": "openai-reasoning-family",
        "vendor": "openai",
        "displayName": "OpenAI reasoning models",
        "matchers": [
            "\\bo1\\b",
            "\\bo1-mini\\b",
            "\\bo3\\b",
            "\\bo4-mini\\b"
        ],
        "capabilities": ["chat"],
        "inputCapabilities": ["image", "file"],
        "notes": "Reasoning models with image/file understanding where documented through OpenAI multimodal APIs."
    },
    {
        "id": "openai-audio-chat-family",
